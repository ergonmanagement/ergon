# ---------------------------------------------------------------------------
# .env.local.example
#
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is in .gitignore.
# ---------------------------------------------------------------------------

# --- Supabase ---
# Found at: https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# --- Mapbox (optional — enables address map preview on job detail) ---
# Get a public token at: https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.eyJ1...

# ---------------------------------------------------------------------------
# Review Request Worker
#
# Required for the automated post-payment review request email.
# Uses Brevo (https://brevo.com) — free tier, no domain required.
# These must also be set as Supabase Edge Function secrets:
#
#   supabase secrets set BREVO_API_KEY=xkeysib-...
#   supabase secrets set BREVO_FROM_EMAIL=you@yourdomain.com
#
# Template variables available in companies.review_email_template:
#   {{customer_first_name}}  — first word of the customer's name
#   {{company_name}}         — your company name from the companies table
#   {{review_link}}          — companies.review_link (e.g. Google review URL)
#
# Per-company DB settings (editable in the Settings UI):
#   review_automation_enabled   — boolean, default false (master on/off)
#   review_link                 — the URL included in the email
#   review_request_delay_hours  — hours after "paid" before sending, default 24
#   review_email_template       — custom email body (null = use built-in default)
# ---------------------------------------------------------------------------
BREVO_API_KEY=xkeysib-your-brevo-api-key-here
BREVO_FROM_EMAIL=you@yourdomain.com
